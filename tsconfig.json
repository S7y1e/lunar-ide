{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "jsx": "react-jsx",
        "lib": ["es2022", "dom", "dom.iterable"]
    },
    "include": ["src"]
}
