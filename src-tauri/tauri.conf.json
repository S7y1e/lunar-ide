{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Lunar",
    "version": "1.9.0",
    "identifier": "dev.S7y1e.lunar-ide",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build"
    },
    "app": {
        "windows": [
            {
                "title": "Lunar",
                "width": 800,
                "height": 600,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "externalBin": [
            "binaries/luau-lsp",
            "binaries/rojo",
            "binaries/argon",
            "binaries/rokit"
        ],
        "resources": ["resources/globalTypes.PluginSecurity.d.luau"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "android": {
            "debugApplicationIdSuffix": ".debug"
        }
    }
}
